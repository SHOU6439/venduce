# Copy this file to .env and fill in the real values. Do NOT commit .env to git.
# Example development values for JWT using RS256.
# Generate keys with `backend/scripts/generate_jwt_keys.sh` and paste the PEM contents below.

# Choose algorithm: RS256 (recommended) or HS256 (simple)
JWT_ALGORITHM=RS256

# If using RS256, set PEM contents (include full BEGIN/END lines). Example placeholder:
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""

# If using HS256 instead, use a long random secret and set JWT_ALGORITHM=HS256
# JWT_SECRET_KEY="a-very-long-random-secret-change-in-prod"
JWT_SECRET_KEY=""

# Database and mail are set in compose.yml by default, but you can override here
# DATABASE_URL=postgresql://pride_user:pride_password@postgres:5432/pride_db
# MAIL_HOST=mailhog
# MAIL_PORT=1025

# Sentry DSN (optional)
# SENTRY_DSN=
