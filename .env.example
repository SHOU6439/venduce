# Copy this file to .env and fill in the real values. Do NOT commit .env to git.
# Example development values for JWT using RS256.
# Generate keys with `backend/scripts/generate_jwt_keys.sh` and paste the PEM contents below.

# -------------------------------------------------------------------
# 共通設定
# -------------------------------------------------------------------

# 環境識別子: "development"（デフォルト）または "production"
# development: MailHog に送信（compose.yml の設定で自動接続）
# production : Resend API で実メール送信
APP_ENV=development

# Next.jsとNodeの起動モード ("development" または "production")
NODE_ENV=development

# Choose algorithm: RS256 (recommended) or HS256 (simple)
JWT_ALGORITHM=RS256

# -------------------------------------------------------------------
# 開発環境 (docker compose 起動時は下記は不要、compose.yml で自動設定済み)
# -------------------------------------------------------------------
# DATABASE_URL=postgresql://venduce_user:venduce_password@postgres:5432/venduce_db

# -------------------------------------------------------------------
# 本番環境必須設定 (APP_ENV=production のときに設定する)
# -------------------------------------------------------------------

# 本番フロントエンド URL（メール内の確認 URL 等に使用する）
# FRONTEND_URL=https://venduce.com

# Resend API キー（実メール送信に使用）
# https://resend.com/api-keys から取得してください
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# メール送信者表示名（デフォルト: "Venduce <no-reply@venduce.com>"）
# MAIL_FROM=Venduce <no-reply@venduce.com>

# Sentry DSN (optional)
# SENTRY_DSN=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
TUNNEL_TOKEN=a1b2c3d4-e5f6-7890-1234-567890abcdef
