# Copy this file to .env and fill in the real values. Do NOT commit .env to git.
# Production environment settings for Venduce.
# Run `make prod-setup` to initialize the production environment.

# -------------------------------------------------------------------
# 共通設定
# -------------------------------------------------------------------

# 環境識別子
APP_ENV=production

# Choose algorithm: RS256 (recommended) or HS256 (simple)
JWT_ALGORITHM=RS256

# -------------------------------------------------------------------
# 本番環境必須設定
# -------------------------------------------------------------------

# 本番フロントエンド URL（メール内の確認 URL 等に使用する）
FRONTEND_URL=https://venduce.com

# 本番 API の公開 URL（フロントエンドから叩く API の Base URL）
NEXT_PUBLIC_API_BASE_URL=https://venduce.com/api

# Resend API キー（実メール送信に使用）
# https://resend.com/api-keys から取得してください
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# メール送信者表示名
MAIL_FROM=Venduce <no-reply@venduce.com>

# -------------------------------------------------------------------
# JWT 鍵（make keys で自動生成・設定されます）
# -------------------------------------------------------------------
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem

# -------------------------------------------------------------------
# Cloudflare Tunnel トークン
# https://one.dash.cloudflare.com/ からトンネルを作成して取得してください
# -------------------------------------------------------------------
TUNNEL_TOKEN=your-cloudflare-tunnel-token-here

# -------------------------------------------------------------------
# オプション
# -------------------------------------------------------------------
# Sentry DSN (optional)
# SENTRY_DSN=
